{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NonInteractive -ExecutionPolicy Bypass -Command \"try{[void][System.Console]::In.ReadToEnd()}catch{};$b=(@{sessionId=1;event='stop'}|ConvertTo-Json -Compress);try{Invoke-RestMethod -Uri 'http://127.0.0.1:5189/hook' -Method POST -Body $b -ContentType 'application/json' -TimeoutSec 3|Out-Null}catch{} # ccc-hook\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NonInteractive -ExecutionPolicy Bypass -Command \"$stdin=try{[System.Console]::In.ReadToEnd()}catch{'{}'}; $d=try{$stdin|ConvertFrom-Json}catch{[PSCustomObject]@{}}; $tool=if($d.tool_name){[string]$d.tool_name}else{'unknown'}; $b=(@{sessionId=1;event='pretooluse';tool=$tool;toolInput=$d.tool_input}|ConvertTo-Json -Compress -Depth 6); $code=0; try{$r=Invoke-RestMethod -Uri 'http://127.0.0.1:5189/hook' -Method POST -Body $b -ContentType 'application/json' -TimeoutSec 60; $code=[int]$r.exitCode}catch{}; exit $code # ccc-hook\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NonInteractive -ExecutionPolicy Bypass -Command \"$stdin=try{[System.Console]::In.ReadToEnd()}catch{'{}'}; $d=try{$stdin|ConvertFrom-Json}catch{[PSCustomObject]@{}}; $msg=if($d.message){[string]$d.message}else{''}; $b=(@{sessionId=1;event='notification';message=$msg}|ConvertTo-Json -Compress); try{Invoke-RestMethod -Uri 'http://127.0.0.1:5189/hook' -Method POST -Body $b -ContentType 'application/json' -TimeoutSec 3|Out-Null}catch{} # ccc-hook\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"C:/Users/11584/AppData/Local/Temp/ccc-statusline-1.js\"",
    "refreshInterval": 5
  }
}